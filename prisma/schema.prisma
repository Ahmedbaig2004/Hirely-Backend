generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]

}


model Interview {
  id             String   @id @default(uuid()) // Use UUID to match Redis SessionID
  interviewType  String   @default("JOB_SPECIFIC") // JOB_SPECIFIC | TECHNICAL | BEHAVIORAL
  config         Json?    // { stack?, difficulty, questionCount } for non-JD types
  jobDescription String?  // Required only for JOB_SPECIFIC
  userId         String   // <--- LINK TO SUPABASE USER ID
  finalScore     Float?
  finalFeedback  Json?    // Store the "Final Report" JSON here
  createdAt      DateTime @default(now())
  
  // Link to Candidate (Optional for now if you don't have auth)


  turns       InterviewTurn[] // The list of Q&A

  @@index([userId])
  @@index([createdAt])
}

model InterviewTurn {
  id          Int      @id @default(autoincrement())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  question    String
  answer      String
  score       Int
  feedback    String
  improvedAnswer String? // "Better Answer" (Point #2)
  topic          String?  
  difficulty     String?
  softSkillScore Int?
  answerMode     String?          // "audio" or "chat" (null for legacy data)
  audioUrl       String?          // Supabase Storage public URL for the recorded answer

  // Delivery analysis (Gemini text modality)
  deliveryScore     Float?
  fillerCount       Int?
  hedgingCount      Int?
  sentenceRestarts  Int?
  relevanceScore    Float?
  specificityScore  Float?
  deliveryFeedback  Json?          // Full structured delivery analysis

  // Voice analysis relationship
  voiceAnalysis   VoiceAnalysis?

  createdAt   DateTime @default(now())

  @@index([interviewId])
}

model VoiceAnalysis {
  id                  Int      @id @default(autoincrement())
  interviewTurnId     Int      @unique
  interviewTurn       InterviewTurn @relation(fields: [interviewTurnId], references: [id], onDelete: Cascade)

  // Predictions
  confidenceLevel     Float?
  confidenceLabelText String?

  // Voice Quality Metrics
  speakingQuality     Float?
  vocalStability      Float?
  speakingFluency     Float?

  // Detailed Features (for audit trail)
  pitchMean           Float?
  pitchStd            Float?
  energyLevel         Float?
  wordsPerMinute      Float?
  pauseRatio          Float?
  jitter              Float?
  shimmer             Float?

  // Model Info
  modelVersion        String?
  allProbabilities    Json?    // {"High": 78.5, "Medium": 15.2, "Low": 6.3}
  rawFeatures         Json?    // All 23 features stored

  // Processing
  status              String   @default("pending")
  errorMessage        String?
  processingTimeMs    Int?

  // Timestamps
  processedAt         DateTime?
  createdAt           DateTime @default(now())
}

model Document {
  id        Int                         @id @default(autoincrement())
  content   String
  embedding Unsupported("vector(3072)")?
  metadata  Json?
  source    String?
  createdAt DateTime                    @default(now())
}

model CodingQuestion {
  id              Int        @id @default(autoincrement())
  problemId       Int        @unique
  title           String     @unique
  slug            String     @unique
  difficulty      String                  // "Easy", "Medium", "Hard"
  category        String                  // Auto-derived DSA pattern: "Two Pointers", "Dynamic Programming", etc.
  description     String                  // Full problem statement
  topics          String[]                // All topic tags: ["Array", "Hash Table"]
  examples        Json?      @db.JsonB    // Array of {example_num, example_text, images}
  constraints     String[]                // Constraint strings
  codeSnippets    Json?      @db.JsonB    // { "python3": "...", "javascript": "...", ... }
  hints           String[]                // Progressive hint strings
  solution        String?                 // Markdown solution
  masterSolution  String?                 // Gemini-generated Python3 stdin/stdout solution
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  testCases       TestCase[]
}

model TestCase {
  id                Int            @id @default(autoincrement())
  codingQuestionId  Int
  codingQuestion    CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
  input             String         // stdin string
  expectedOutput    String         // expected stdout string
  category          String         // "basic" | "edge" | "stress"
  isVerified        Boolean        @default(false)
  createdAt         DateTime       @default(now())

  @@index([codingQuestionId])
}