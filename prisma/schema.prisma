generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Candidate {
  id        Int      @id @default(autoincrement())
  // For now, we can keep it simple or add more fields later
  name      String?  
  email     String?  @unique
  interviews Interview[]
}

model Interview {
  id          String   @id @default(uuid()) // Use UUID to match Redis SessionID
  jobDescription String
  finalScore  Float?
  finalFeedback Json?  // Store the "Final Report" JSON here
  createdAt   DateTime @default(now())
  
  // Link to Candidate (Optional for now if you don't have auth)
  candidateId Int?
  candidate   Candidate? @relation(fields: [candidateId], references: [id])

  turns       InterviewTurn[] // The list of Q&A
}

model InterviewTurn {
  id          Int      @id @default(autoincrement())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id])
  
  question    String
  answer      String
  score       Int
  feedback    String
  improvedAnswer String? // "Better Answer" (Point #2)
  topic          String?  
  difficulty     String?
  softSkillScore Int?    // (Point #2 - Placeholder)
  
  createdAt   DateTime @default(now())
}

model Document {
  id        Int                         @id @default(autoincrement())
  content   String
  embedding Unsupported("vector(768)")?
  metadata  Json?
  source    String?
  createdAt DateTime                    @default(now())
}