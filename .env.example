# Backend Production Configuration (.env)
# ⚠️  IMPORTANT: This file should NOT be committed to version control
# Use environment variables or a secrets manager in production

# Database Configuration
# Use your Supabase cloud connection strings
DATABASE_URL="postgresql://user:password@your-db-host:6543/postgres"
DATABASE_DIRECT_URL="postgresql://user:password@your-db-host:5432/postgres"

# Redis Configuration (Cloud Redis service)
# Examples:
#   AWS ElastiCache: redis://redis-hostname:6379
#   Redis Cloud: redis://username:password@redis-cloud-host:port
REDIS_URL="redis://your-redis-host:6379"

# API Keys (Keep secure - use environment variables/secrets manager)
GOOGLE_API_KEY="your_google_gemini_api_key"
GROQ_API_KEY="your_groq_api_key"
DEEPGRAM_API_KEY="your_deepgram_api_key"

# Voice Service Configuration
# URL of your deployed Python voice analysis service
VOICE_SERVICE_URL="https://your-voice-service-domain.com"

# Text-to-Speech Toggle
ENABLE_TTS=true

# Server Configuration
PORT=4000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL="https://your-frontend-domain.com"
